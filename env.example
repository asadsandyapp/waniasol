# Copy to .env.local (never commit .env.local)

# --- Contact submissions (Upstash Redis — free tier: https://upstash.com )
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- /response admin page (view stored submissions)
CONTACT_ADMIN_PASSWORD=
# Optional extra secret used to sign the session cookie (set in production)
CONTACT_ADMIN_SECRET=
